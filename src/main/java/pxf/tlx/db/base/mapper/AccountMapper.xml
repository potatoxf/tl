        <include refid="AccountConLog_Columns" />
        from base_account_con_log
        where id = #{id,jdbcType=VARCHAR}
        <if test="condition.fromTimestamp != null">
            and created_time >= #{condition.fromTimestamp,jdbcType=BIGINT}
        </if>
    </select>

